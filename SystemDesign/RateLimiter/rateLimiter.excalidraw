      "index": "b0A",
      "roundness": null,
      "seed": 1648300175,
      "version": 441,
      "versionNonce": 2117303425,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784045129019,
      "link": null,
      "locked": false,
      "text": "X-RateLimit-Limit: Represents the total maximum number of requests allowed within the configured time window (e.g., 100).\n\nX-RateLimit-Remaining: Represents the number of remaining requests the user can make inside the current sliding window before being throttled (e.g., 38).\n\nX-RateLimit-Reset: A Unix timestamp indicating exactly when the current window expires and resets back to full capacity (e.g., 1775874600).\n\nRetry-After: The standard HTTP header sent back alongside a 429 Too Many Requests status code, \ntelling the client exactly how many seconds they must wait before making another request.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "X-RateLimit-Limit: Represents the total maximum number of requests allowed within the configured time window (e.g., 100).\n\nX-RateLimit-Remaining: Represents the number of remaining requests the user can make inside the current sliding window before being throttled (e.g., 38).\n\nX-RateLimit-Reset: A Unix timestamp indicating exactly when the current window expires and resets back to full capacity (e.g., 1775874600).\n\nRetry-After: The standard HTTP header sent back alongside a 429 Too Many Requests status code, \ntelling the client exactly how many seconds they must wait before making another request.",
      "autoResize": true,
      "lineHeight": 1.25
    }
